# ============================================================
# XTB Trading Bot - Configuration
# ============================================================
# Copiez ce fichier en ".env" et remplissez vos identifiants.
#   copy .env.example .env
# NE COMMITEZ JAMAIS le fichier .env !
# ============================================================

# --- Identifiants ---
# Créez un compte démo sur https://xopenhub.pro/try-demo/
# puis utilisez le numéro de compte et le mot de passe reçus.
XTB_USER_ID=votre_identifiant
XTB_PASSWORD=votre_mot_de_passe

# --- Serveur API ---
# L'API XTB (ws.xtb.com) a été fermée en mars 2025.
# Utilisez ws.xapi.pro (X Open Hub, filiale XTB) à la place.
XTB_HOST=ws.xapi.pro

# --- Mode de trading ---
# "demo" pour le compte démo, "real" pour le compte réel
XTB_MODE=demo

# --- Actif à trader ---
SYMBOL=EURUSD

# --- Paramètres de stratégie ---
MA_FAST=20
MA_SLOW=50

# --- Gestion du risque ---
VOLUME=0.01
STOP_LOSS_PIPS=50
TAKE_PROFIT_PIPS=100

# --- Intervalle d'analyse (secondes) ---
LOOP_INTERVAL=30

# --- Mode simulation (paper trading) ---
# true = aucun ordre réel envoyé, false = ordres réels
PAPER_TRADING=true
